{
  "name": "sendx",
  "version": "1.0.1",
  "description": "SendX — Disparador de E-mails em Massa",
  "main": "main.js",
  "author": "GHZ Plugin",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.ghzplugin.sendx",
    "productName": "SendX",
    "directories": {
      "output": "dist_installer"
    },
    "files": [
      "**/*",
      "!dist_installer/**",
      "!node_modules/.cache/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SendX"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "nodemailer": "^6.9.0"
  }
}
